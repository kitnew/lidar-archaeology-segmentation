  file = {Full Text PDF:/home/nikitachernysh/Zotero/storage/ZE53FJZI/Fylaktos et al. - 2025 - A Deep Learning Method for the Automated Mapping of Archaeological Structures from Geospatial Data.pdf:application/pdf},
