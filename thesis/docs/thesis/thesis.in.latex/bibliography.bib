  keywords = {deep learning, convolutional neural network, old aerial images, YOLO v8, Zuzan Historical City, maybe},
  pages = {409--418},
  file = {Full Text PDF:/home/nikitachernysh/Zotero/storage/8CE89ZBX/Azarkhordad et al. - 2025 - Detecting Archaeological Phenomena Using Deep Learning in the Study of the Old Aerial Images of Hist.pdf:application/pdf;Snapshot:/home/nikitachernysh/Zotero/storage/JEFQFNKR/arp.html:text/html},
